{
  "autoMemoryEnabled": false,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python3 \"${CLAUDE_PROJECT_DIR:-.}/scripts/memory_retrieval_hook.py\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '\"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/tdd-test-lock.sh\"'",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
