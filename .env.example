# === Required ===
CLAUDE_CODE_OAUTH_TOKEN=

# === Channels ===
TELEGRAM_BOT_TOKEN=
ASSISTANT_NAME=Deus
ASSISTANT_HAS_OWN_NUMBER=false

# === AI / API Keys ===
OPENAI_API_KEY=
GEMINI_API_KEY=

# === Voice Transcription ===
WHISPER_LANG=en
WHISPER_BIN=whisper-cli
WHISPER_MODEL=

# === Container Runtime ===
CONTAINER_RUNTIME=docker
CONTAINER_IMAGE=deus-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
IDLE_TIMEOUT=1800000
CONTAINER_MAX_OUTPUT_SIZE=10485760

# === Credential Proxy ===
CREDENTIAL_PROXY_PORT=3001
CREDENTIAL_PROXY_HOST=

# === Evolution / Eval ===
EVAL_JUDGE=
EVOLUTION_REFLECTION_THRESHOLD=0.6
EVOLUTION_AUTO_OPTIMIZE_THRESHOLD=50
EVOLUTION_PRINCIPLES_COOLDOWN_HOURS=24
DEUS_EVAL_CONCURRENT=

# === Memory ===
DEUS_VAULT_PATH=

# === Safety ===
# Max characters per incoming message (truncates, doesn't reject)
MAX_MESSAGE_LENGTH=50000

# === Logging ===
LOG_LEVEL=info
